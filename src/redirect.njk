---
permalink: /index.html
---
{% set defaultLocale = i18n._meta.defaultLocale %}
<!DOCTYPE html>
{#- Page copy is English regardless of defaultLocale; lang/dir reflect the copy, not the redirect target #}
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Redirecting…</title>
  <script>
    (function () {
      var locales = {
        {% for slug, entry in i18n._meta.locales %}
        "{{ slug }}": "/{{ slug }}/"{% if not loop.last %},{% endif %}
        {% endfor %}
      };

      var aliases = {
        {%- set aliasEntries = [] %}
        {%- for slug, entry in i18n._meta.locales %}
        {%- for alias in entry.aliases %}
        {%- set _ = aliasEntries.push('"' + (alias | lower) + '": "' + slug + '"') %}
        {%- endfor %}
        {%- endfor %}
        {{ aliasEntries | join(",\n        ") }}
      };

      var fallback = "{{ defaultLocale }}";

      function match(tag) {
        tag = tag.toLowerCase();
        if (locales[tag]) return tag;
        if (aliases[tag]) return aliases[tag];
        var prefix = tag.split("-")[0];
        if (locales[prefix]) return prefix;
        if (aliases[prefix]) return aliases[prefix];
        return null;
      }

      var matched = null;
      var langs = navigator.languages || [navigator.language || ""];
      for (var i = 0; i < langs.length; i++) {
        matched = match(langs[i]);
        if (matched) break;
      }

      var locale = matched || fallback;
      location.replace(locales[locale] || locales[fallback]);
    })();
  </script>
  <style>
    body {
      margin: 0;
      font-family: Georgia, serif;
      background: #f8f8f8;
      color: #111111;
    }

    main {
      max-width: 42rem;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }

    h1 {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    p {
      line-height: 1.6;
      margin: 0 0 1rem;
    }

    ul {
      margin: 1.25rem 0 0;
      padding-left: 1.25rem;
    }

    li + li {
      margin-top: 0.5rem;
    }

    a {
      color: #1650a8;
    }
  </style>
</head>
<body>
  <main>
    <h1>Redirecting…</h1>
    <p>If automatic language detection does not run, continue with the default version or choose one of the available locales below.</p>
    <p><a href="/{{ defaultLocale }}/">Continue in {{ i18n[defaultLocale].label }}</a></p>
    <ul>
      {% for slug, entry in i18n._meta.locales %}
      <li><a href="/{{ slug }}/">{{ entry.label }}</a>{% if slug == defaultLocale %} (default){% endif %}</li>
      {% endfor %}
    </ul>
    <noscript>
      <meta http-equiv="refresh" content="0;url=/{{ defaultLocale }}/" />
      <p>JavaScript is disabled — redirecting to the <a href="/{{ defaultLocale }}/">{{ i18n[defaultLocale].label }} version</a>.</p>
    </noscript>
  </main>
</body>
</html>
